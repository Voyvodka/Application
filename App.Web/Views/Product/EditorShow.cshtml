@model Stock

<div class="card">
    <div class="card-body px-2">
        <div class="form-floating mb-3">
            <input type="text" class="form-control" disabled asp-for="@Model.Name" />
            <label for="Name">Ürün Adı</label>
        </div>
        <div class="form-floating mb-3">
            <input type="text" class="form-control" disabled asp-for="@Model.Barcode" />
            <label for="Barcode">Barkod</label>
        </div>
        <div class="form-floating mb-3">
            <input type="number" class="form-control" disabled asp-for="@Model.PackageSize" />
            <label for="PackageSize">Paket Boyutu</label>
        </div>
        <div class="form-floating mb-3">
            <select class="form-select" asp-for="@Model.UnitId" disabled aria-label="Birim">
                <option value="@Model.UnitId">@Model.UnitName</option>
            </select>
            <label for="UnitId">Birim</label>
        </div>
        <div class="d-flex justify-content-end">
            <a href='@Url.Action("Create",new {Id = Model.Id})' class="btn btn-sm btn-info">Düzenle</a>
        </div>
    </div>
</div>