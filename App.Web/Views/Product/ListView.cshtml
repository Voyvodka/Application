@model List<Stock>
@{
    Layout = "";
}

<div class="d-flex flex-stack mb-5">
    <div class="d-flex align-items-center position-relative my-1">
        <i class="ki-duotone ki-magnifier fs-1 position-absolute ms-6"><span class="path1"></span><span
                class="path2"></span></i>
        <input type="text" data-kt-docs-table-filter="search" class="form-control form-control-solid w-250px ps-15"
            placeholder="Aramak" />
    </div>

    <div class="d-flex justify-content-end" data-kt-docs-table-toolbar="base">
        <button type="button" class="btn btn-light-primary me-3" data-bs-toggle="tooltip" title="Coming Soon">
            <i class="ki-duotone ki-filter fs-2"><span class="path1"></span><span class="path2"></span></i>
            Filtre
        </button>

        <button type="button" class="btn btn-primary" data-bs-toggle="tooltip" title="Coming Soon">
            <i class="ki-duotone ki-plus fs-2"></i>
            Ekle
        </button>
    </div>

    <div class="d-flex justify-content-end align-items-center d-none" data-kt-docs-table-toolbar="selected">
        <div class="fw-bold me-5">
            <span class="me-2" data-kt-docs-table-select="selected_count"></span> Selected
        </div>

        <button type="button" class="btn btn-danger" data-bs-toggle="tooltip" title="Coming Soon">
            Selection Action
        </button>
    </div>
</div>

<table id="kt_datatable_example_1" class="table align-middle table-row-dashed fs-6 gy-5">
    <thead>
        <tr class="text-start text-gray-500 fw-bold fs-7 text-uppercase gs-0">
            <th class="w-10px pe-2">
                <div class="form-check form-check-sm form-check-custom form-check-solid me-3">
                    <input class="form-check-input" type="checkbox" data-kt-check="true"
                        data-kt-check-target="#kt_datatable_example_1 .form-check-input" value="1" />
                </div>
            </th>
            <th>Name</th>
        </tr>
    </thead>
    <tbody class="text-gray-600 fw-semibold">
    </tbody>
</table>

<script>
    var KTDatatablesServerSide = function () {
        var table;
        var dt;
        var filterPayment;

        var initDatatable = function () {
            dt = $("#kt_datatable_example_1").DataTable({
                searchDelay: 10,
                processing: true,
                serverSide: true,
                stateSave: true,
                select: {
                    style: 'multi',
                    selector: 'td:first-child input[type="checkbox"]',
                    className: 'row-selected'
                },
                ajax: {
                    url: "@Url.Action("GetStocks")",
                },
                columns: [
                    { data: 'Id' },
                    { data: 'Name' },
                ],
                columnDefs: [
                    {
                        targets: 0,
                        orderable: false,
                        render: function (data) {
                            console.log(data);
                            return `
                            <div class="form-check form-check-sm form-check-custom form-check-solid">
                                <input class="form-check-input" type="checkbox" value="${data}" />
                            </div>`;
                        }
                    },
                ]
            });

            table = dt.$;

            dt.on('draw', function () {
                KTMenu.createInstances();
            });
        }

        return {
            init: function () {
                initDatatable();
            }
        }
    }();

    KTUtil.onDOMContentLoaded(function () {
        KTDatatablesServerSide.init();
    });
</script>